{
  "name": "wizclaw",
  "version": "1.0.0",
  "description": "WizClaw — visual setup wizard for NanoClaw, a native installer for non-technical users",
  "license": "MIT",
  "author": "Víctor Vásquez",
  "repository": {
    "type": "git",
    "url": "https://github.com/SonryP/wizclaw.git"
  },
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsc && electron dist/index.js",
    "build": "tsc",
    "start": "electron dist/index.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0"
  },
  "build": {
    "appId": "com.nanoclaw.wizard",
    "productName": "NanoClaw Setup",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
